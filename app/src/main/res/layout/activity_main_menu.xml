<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CÁC LAYOUT CƠ BẢN"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="30dp"
        android:textColor="@color/purple_700"/>

    <Button
        android:id="@+id/btn_1a"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bài 1A - LinearLayout (Code)"
        android:layout_margin="10dp"/>

    <Button
        android:id="@+id/btn_1b"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bài 1B - LinearLayout (XML)"
        android:layout_margin="10dp"/>

    <Button
        android:id="@+id/btn_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bài 2 - RelativeLayout"
        android:layout_margin="10dp"/>

    <Button
        android:id="@+id/btn_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bài 3 - ConstraintLayout"
        android:layout_margin="10dp"/>

</LinearLayout>


